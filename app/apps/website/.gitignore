# TypeScript
*.tsbuildinfo
next-env.d.ts

# Stale tsc-emitted .js siblings of .tsx/.ts sources. Should never exist
# under src/ or next to next.config.ts — if they appear, somebody ran `tsc`
# without --noEmit at the wrong scope. Root tsconfig.json now has
# noEmit:true to prevent regression. Keep this rule so accidental emits
# don't get committed and surface as ignored on `git status`.
/src/**/*.js
/src/**/*.js.map
/src/**/*.d.ts
/next.config.js
/next.config.js.map

# IDE
.vscode/*
!.vscode/extensions.json
.idea

# Other
dev-dist

.wrangler
.dev.vars*

.open-next
