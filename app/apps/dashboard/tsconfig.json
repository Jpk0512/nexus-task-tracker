{
	"extends": "@nexus-app/tsconfig/nextjs.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@api/*": ["../api/src/*"],
			"@ui/*": ["../../packages/ui/src/*"],
			"@integration/*": ["../../packages/integration/src/*"],
			"@notifications/*": ["../../packages/notifications/src/*"],
			"@jobs/*": ["../../packages/jobs/src/*"]
		},
		"strict": true,
		"strictNullChecks": false,
		"verbatimModuleSyntax": true
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"./.next/types/**/*.ts",
		"./next-env.d.ts",
		".next/types/**/*.ts"
	],
	"exclude": ["**/node_modules", "**/.*/", ".next", "next.config.ts"]
}
