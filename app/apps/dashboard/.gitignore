# TypeScript
*.tsbuildinfo
next-env.d.ts

# Stale tsc-emitted .js siblings of .tsx/.ts sources. Should never exist
# under src/ — if they appear, somebody ran `tsc` without --noEmit at the
# wrong scope. Root tsconfig.json now has noEmit:true to prevent regression.
# Keep this rule so accidental emits don't get committed.
/src/**/*.js
/src/**/*.js.map
/src/**/*.d.ts

# IDE
.vscode/*
!.vscode/extensions.json
.idea

# Other
dev-dist

.wrangler
.dev.vars*

.open-next

# Sentry Config File
.env.sentry-build-plugin
