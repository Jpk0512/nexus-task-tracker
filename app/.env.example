# Copy this file to .env.local and the docker-compose stack picks it up.
# Real secrets are intentionally absent — local dev runs against stubs.

# Local-dev master switch — stubs all paid integrations.
MIMRAI_LOCAL_DEV=1
NEXT_PUBLIC_MIMRAI_LOCAL_DEV=1

# Runtime
NODE_ENV=development
PORT=3003

# Database (mapped to the postgres container)
DATABASE_URL=postgresql://mimrai:mimrai@postgres:5432/mimrai

# Better Auth — pick a 32+ char random string for real use
BETTER_AUTH_SECRET=local_dev_secret_change_me_min_32_characters_long
BETTER_AUTH_DOMAIN=http://localhost:5179

# API CORS
ALLOWED_API_ORIGINS=http://localhost:5179

# Supabase — dummy. Not used in local flow (DB goes through DATABASE_URL).
SUPABASE_URL=http://supabase-not-used.local
SUPABASE_SERVICE_KEY=dummy_supabase_service_key
SUPABASE_ANON_KEY=dummy_supabase_anon_key

# Upstash — stubbed in-process via packages/realtime/src/redis-client.ts when
# MIMRAI_LOCAL_DEV=1. Values below are placeholders; the code never hits them.
UPSTASH_REDIS_REST_URL=http://stub.local
UPSTASH_REDIS_REST_TOKEN=stub_local_dev_token

# Billing — disabled via MIMRAI_LOCAL_DEV + DISABLE_BILLING. Dummy keys keep constructors happy.
DISABLE_BILLING=true
STRIPE_SECRET_KEY=sk_test_dummy_for_local_dev
STRIPE_WEBHOOK_SECRET=whsec_dummy_for_local_dev

# Email (Resend) — stubbed.
RESEND_API_KEY=re_dummy_for_local_dev

# AI (OpenAI) — stubbed embeddings + AI flows.
OPENAI_API_KEY=sk-dummy-for-local-dev

# Analytics (OpenPanel) — stubbed.
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=

# Error tracking (Sentry) — gated off.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Background jobs (Trigger.dev) — gated off; dummy token.
TRIGGER_SECRET_KEY=tr_dev_dummy_for_local_dev

# PostHog — SDK throws on empty key, so use a phc_ placeholder. MIMRAI_LOCAL_DEV
# disables actual reporting elsewhere.
POSTHOG_KEY=phc_local_dev_dummy_posthog_key
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_local_dev_dummy_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OAuth integrations — unused in local dev unless you wire your own creds.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
TWILIO_AUTH_TOKEN=

# Public dashboard vars
NEXT_PUBLIC_APP_URL=http://localhost:5179
NEXT_PUBLIC_SERVER_URL=http://localhost:3003
NEXT_PUBLIC_GITHUB_APP_NAME=
NEXT_PUBLIC_SLACK_CLIENT_ID=
NEXT_PUBLIC_SITE_URL=http://localhost:3001
