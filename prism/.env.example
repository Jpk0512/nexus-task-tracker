### Anthropic / Claude SDK
# API key — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure AI Services endpoint (optional — if routing through Azure instead of direct Anthropic)
# Strip trailing /v1 if present; the SDK adds it back
AI_API_BASE_URL=https://your-resource.services.ai.azure.com/anthropic

# Model ID — claude-sonnet-4-6 recommended for PRISM root-cause stage
ANTHROPIC_MODEL=claude-sonnet-4-6

### LM Studio (local models — triage + diagnose stages)
# LM Studio default: http://localhost:1234
PRISM_LM_STUDIO_URL=http://localhost:1234

# Model IDs must match exactly what LM Studio shows (not HuggingFace slugs)
PRISM_TRIAGE_MODEL=granite-4.1-3b
PRISM_DIAGNOSE_MODEL=qwen3-30b-a3b-mlx
PRISM_EMBED_MODEL=text-embedding-qwen3-embedding-8b

### Qdrant (vector DB for bug genome)
QDRANT_URL=http://localhost:6333
