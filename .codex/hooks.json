{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh beforeShellExecution no-direct-push-to-session-branch.sh worktree-guard.sh",
        "failClosed": false,
        "timeout": 30
      }
    ],
    "beforeReadFile": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh beforeReadFile read-injection-scanner.sh",
        "failClosed": false,
        "timeout": 30
      }
    ],
    "afterFileEdit": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh afterFileEdit verify-after-edit.sh reflection-capture.sh",
        "failClosed": false,
        "timeout": 60
      }
    ],
    "beforeSubmitPrompt": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh beforeSubmitPrompt context-reset-monitor.py",
        "failClosed": false,
        "timeout": 15
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh stop memory-consolidator.sh \"sh:python3 ./.memory/log.py context snapshot --action-type session_stop --summary 'Auto-snapshot at Codex stop' 2>/dev/null || true\" session-end-reminder.sh",
        "failClosed": false,
        "timeout": 60
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh sessionStart \"sh:python3 ./.memory/log.py session reap --max-age-hours 2 2>/dev/null || true\" \"sh:python3 ./.memory/log.py memory retain 2>/dev/null || true\" lesson-harvester.sh router-health-check.sh health-banner.sh",
        "failClosed": false,
        "timeout": 30
      }
    ],
    "subagentStart": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh subagentStart broker-gate.py skills-required-guard.sh persona-alias-resolver.sh parallel-first-check.sh",
        "failClosed": false,
        "timeout": 30
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "command": ".codex/hooks/codex-adapter.sh subagentStop lens-gate.sh root-cause-gate.sh verify-deliverables.sh return-summarizer.sh",
        "failClosed": false,
        "timeout": 60
      }
    ]
  }
}
