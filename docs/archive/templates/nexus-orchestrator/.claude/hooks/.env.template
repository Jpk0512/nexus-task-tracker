# Nexus Hook Environment Variables
# Copy to .claude/hooks/.env and customize for your project
export REPO_ROOT="${REPO_ROOT:-$(pwd)}"
export DB_PATH="${DB_PATH:-$(pwd)/.memory/project.db}"
export GATED_SOURCE_PATHS="${GATED_SOURCE_PATHS:-app/,src/,lib/}"
export CONTEXT_RESET_AT="${CONTEXT_RESET_AT:-10}"
export SKILL_MAP_PATH="${SKILL_MAP_PATH:-docs/agents/SKILL_MAP.md}"
export NEXUS_PROJECT_NAME="${NEXUS_PROJECT_NAME:-my-project}"

# Router / LM Studio config
export _HOOK_ROUTER_MODEL="${_HOOK_ROUTER_MODEL:-granite-4.1-3b}"
export _HOOK_ROUTER_TIMEOUT="${_HOOK_ROUTER_TIMEOUT:-10.0}"
# Confidence threshold for routing prefill (0.0-1.0); lower = more aggressive routing
export _HOOK_THRESHOLD_LLM="${_HOOK_THRESHOLD_LLM:-0.70}"
# Comma-separated personas to run in shadow mode (observe only, no prefill)
export _HOOK_SHADOW_PERSONAS="${_HOOK_SHADOW_PERSONAS:-}"
