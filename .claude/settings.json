{
  "agent": "nexus-orchestrator",
  "env": {
    "ARIZE_PROJECT_NAME": "nexus-task-tracker",
    "MEMORY_TOOL_PATH": ".memory/files",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(rtk tsc:*)",
      "Bash(rtk lint:*)",
      "Bash(rtk git:*)",
      "Bash(rtk pnpm:*)",
      "Bash(rtk vitest:*)",
      "Bash(rtk ls:*)",
      "Bash(rtk tree:*)",
      "Bash(rtk read:*)",
      "Bash(rtk smart:*)",
      "Bash(rtk diff:*)",
      "Bash(rtk find:*)",
      "Bash(rtk grep:*)",
      "Bash(rtk log:*)",
      "Bash(rtk gh:*)",
      "Bash(rtk env:*)",
      "Bash(rtk wc:*)",
      "Bash(rtk session:*)",
      "Bash(rtk gain:*)",
      "Bash(rtk pytest:*)",
      "Bash(rtk ruff:*)",
      "Bash(rtk mypy:*)",
      "Bash(rtk prettier:*)",
      "Bash(rtk format:*)",
      "Bash(rtk json:*)",
      "Bash(rtk deps:*)",
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv tool:*)",
      "Bash(python3 .memory/log.py:*)",
      "Bash(python3 .memory/sync_docs.py:*)",
      "Bash(python3 .memory/log.py recall:*)",
      "Bash(npm run:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(git:*)",
      "Bash(ax projects:*)",
      "Bash(ax spans export:*)",
      "Bash(ax traces export:*)",
      "Bash(ax sessions export:*)",
      "Bash(ax datasets:*)",
      "Bash(ax experiments:*)",
      "Bash(ax evaluators:*)",
      "Bash(ax profiles:*)",
      "Bash(ax spaces:*)",
      "Bash(ax projects list:*)",
      "Bash(ax ai-integrations:*)",
      "Bash(lms ls:*)",
      "Bash(lms ps:*)",
      "Bash(lms status:*)",
      "Bash(lms server status:*)",
      "Bash(mkdir -p:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(ln -s:*)",
      "Bash(chmod +x:*)",
      "Bash(curl -sf:*)",
      "Bash(curl -s:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(sqlite3:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(comm:*)",
      "Bash(flock:*)",
      "Workflow",
      "Monitor",
      "CronCreate",
      "CronDelete",
      "CronList"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.claude/hooks/router.py 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.memory/log.py context dump 2>/dev/null | python3 -c \"import json,sys; d=json.load(sys.stdin); tasks=[t for t in d.get('open_tasks',[]) if t['status']=='in_progress']; print('\\n[Context] Open in-progress tasks: ' + ', '.join(t['id'] for t in tasks)) if tasks else None\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.claude/hooks/context-reset-monitor.py 2>&1 || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/auto-parallel-nudge.sh || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/worktree-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/no-direct-push-to-session-branch.sh"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/socraticode-gate.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/socraticode-gate.sh"
          }
        ]
      },
      {
        "matcher": "Task|TeamCreate|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/_py.sh /Users/john.keeney/nexus-task-tracker/.claude/hooks/gate_runner.py pretooluse-dispatch"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/secret-path-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/oracle-immutability-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_socraticode_socraticode__.*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/socraticode-flag.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/_py.sh /Users/john.keeney/nexus-task-tracker/.claude/hooks/skill-load-capture.py || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/verify-after-edit.sh"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/reflection-capture.sh 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Task|TeamCreate",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/stall-counter.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|mcp__plugin_socraticode_socraticode__.*|Edit|Write|MultiEdit|NotebookEdit|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/analysis-paralysis-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/read-injection-scanner.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/_py.sh /Users/john.keeney/nexus-task-tracker/.claude/hooks/gate_runner.py subagentstop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.memory/log.py context snapshot --action-type session_stop --summary \"Auto-snapshot at agent stop\" 2>/dev/null || true; python3 /Users/john.keeney/nexus-task-tracker/.memory/sync_docs.py 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/session-end-reminder.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.claude/hooks/lens-tier-backstop.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.memory/log.py session reap --max-age-hours 2 2>/dev/null | python3 -c 'import json,sys; d=json.load(sys.stdin); n=d.get(\"reaped_count\",0); print(f\"[Session Lifecycle] Reaped {n} abandoned session(s) at startup\") if n else None' 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 /Users/john.keeney/nexus-task-tracker/.memory/log.py memory retain 2>/dev/null | python3 -c 'import json,sys; d=json.load(sys.stdin); c=d.get(\"context_log_dropped\",0); f=d.get(\"facts_decayed\",0); print(f\"[Memory Retention] Dry-run: {c} stale context_log rows + {f} unpinned facts past TTL. Apply with: python3 .memory/log.py memory retain --apply\") if (c or f) else None' 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/lesson-harvester.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/router-health-check.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/health-banner.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "/Users/john.keeney/nexus-task-tracker/.claude/hooks/inject-invariants.sh session-start 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
